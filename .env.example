# ─────────────────────────────────────────────────────────────────────────────
# DevCity Pulse — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── IBM WatsonX (required for AI scoring) ────────────────────────────────────
# Get these from IBM Cloud → WatsonX → Project Settings
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# ── JWT Authentication (required — use a long random string, min 32 chars) ───
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/citypulse

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=true

# ── Reddit API (optional — social signal ingestion) ──────────────────────────
# Register at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ── Environment ───────────────────────────────────────────────────────────────
# Values: development | production
ENVIRONMENT=development
